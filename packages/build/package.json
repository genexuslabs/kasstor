{
  "name": "@genexus/kasstor-build",
  "version": "0.5.0",
  "license": "Apache-2.0",
  "homepage": "https://github.com/genexuslabs/kasstor",
  "description": "Utilities to analyze Lit component libraries and auto-generate documentation, type declarations, and metadata.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/genexuslabs/kasstor.git"
  },
  "keywords": [
    "lit",
    "lit decorators",
    "web components"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "jsnext:main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "files": [
    "dist/"
  ],
  "scripts": {
    "dev": "tsc",
    "dev.types": "tsc",
    "build": "tsc",
    "test": "vitest",
    "test.ci": "bun run test --watch=false"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "dependencies": {
    "micromark": "~4.0.2",
    "prettier": "^3.7.4",
    "typescript": "~5.9.3"
  },
  "devDependencies": {
    "lit": "^3.3.2",
    "@genexus/kasstor-core": "^0.5.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  }
}

