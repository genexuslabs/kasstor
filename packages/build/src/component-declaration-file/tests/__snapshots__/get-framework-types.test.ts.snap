exports[`[component-declaration-file] getReactDeclaration > declares ComponentPropertiesReact locally (no core ComponentProperties import) and augments react's IntrinsicElements 1`] = `
"import type {
  DetailedHTMLProps as ReactDetailedHTMLProps,
  HTMLAttributes as ReactHTMLAttributes
} from "react";

// - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
// Types for React JSX templates
// - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
/**
 * Each interface contains the properties of the custom elements of the library.
 * This format is used for React applications.
 */
// eslint-disable-next-line @typescript-eslint/no-namespace
export namespace ComponentPropertiesReact {
  export type KstField = {
    /**
     * 
     */
    value?: string;
  };

  export type KstIcon = {
    /**
     * 
     */
    name?: string;
  };
}

// eslint-disable-next-line @typescript-eslint/no-namespace
declare namespace ReactJSX {
  export type KstField = Omit<ReactDetailedHTMLProps<ReactHTMLAttributes<HTMLKstFieldElement>, HTMLKstFieldElement>, keyof ComponentPropertiesReact.KstField | "onInput"> & ComponentPropertiesReact.KstField & {
    /**
     * Native input event.
     */
    onInput?: (event: HTMLKstFieldElementInputEvent) => void;

    /**
     * Selection changed.
     */
    onselectedItemsChange?: (event: HTMLKstFieldElementSelectedItemsChangeEvent) => void;
  };

  export type KstIcon = Omit<ReactDetailedHTMLProps<ReactHTMLAttributes<HTMLKstIconElement>, HTMLKstIconElement>, keyof ComponentPropertiesReact.KstIcon> & ComponentPropertiesReact.KstIcon;
  
  interface IntrinsicElements {
    /**
     * A form field.
     */
    "kst-field": KstField;
    
    /**
     * An icon.
     */
    "kst-icon": KstIcon;
  }
}

export type { ReactJSX };

declare module "react" {
  // eslint-disable-next-line @typescript-eslint/no-namespace
  namespace JSX {
    // eslint-disable-next-line @typescript-eslint/no-empty-object-type
    interface IntrinsicElements extends ReactJSX.IntrinsicElements {}
  }
}"
`;

