  };

  export type KstIcon = Omit<JSX.HTMLAttributes<HTMLKstIconElement>, keyof ComponentPropertiesSolidJS.KstIcon> & ComponentPropertiesSolidJS.KstIcon;
  
  interface IntrinsicElements {
    /**
     * A form field.
     */
    "kst-field": KstField;
    
    /**
     * An icon.
     */
    "kst-icon": KstIcon;
  }
}

