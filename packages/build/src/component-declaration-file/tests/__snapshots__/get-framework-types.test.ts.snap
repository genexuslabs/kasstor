    variant?: FieldVariant;
  };
}

// eslint-disable-next-line @typescript-eslint/no-namespace
declare namespace ReactJSX {
  export type KstField = Omit<ReactDetailedHTMLProps<ReactHTMLAttributes<HTMLKstFieldElement>, HTMLKstFieldElement>, keyof ComponentPropertiesReact.KstField> & ComponentPropertiesReact.KstField;
  
  interface IntrinsicElements {
    /**
     * A form field.
     */
    "kst-field": KstField;
  }
}

export type { ReactJSX };

declare module "react" {
