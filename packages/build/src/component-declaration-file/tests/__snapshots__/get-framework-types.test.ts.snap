exports[`[component-declaration-file] getReactDeclaration > imports react + the core ComponentProperties and augments react's IntrinsicElements 1`] = `
"import type {
  DetailedHTMLProps as ReactDetailedHTMLProps,
  HTMLAttributes as ReactHTMLAttributes
} from "react";
import type { ComponentProperties } from "./components.js";

// - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
// Types for React JSX templates
// - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
// eslint-disable-next-line @typescript-eslint/no-namespace
declare namespace ReactJSX {
  export type KstField = Omit<ReactDetailedHTMLProps<ReactHTMLAttributes<HTMLKstFieldElement>, HTMLKstFieldElement>, keyof ComponentProperties.KstField> & Partial<ComponentProperties.KstField> & {
    /**
     * Selection changed.
     */
    onselectedItemsChange?: (event: HTMLKstFieldElementSelectedItemsChangeEvent) => void;
  };

  export type KstIcon = Omit<ReactDetailedHTMLProps<ReactHTMLAttributes<HTMLKstIconElement>, HTMLKstIconElement>, keyof ComponentProperties.KstIcon> & Partial<ComponentProperties.KstIcon>;
  
  interface IntrinsicElements {
    /**
     * A form field.
     */
    "kst-field": KstField;
    
    /**
     * An icon.
     */
    "kst-icon": KstIcon;
  }
}

export type { ReactJSX };

declare module "react" {
  // eslint-disable-next-line @typescript-eslint/no-namespace
  namespace JSX {
    // eslint-disable-next-line @typescript-eslint/no-empty-object-type
    interface IntrinsicElements extends ReactJSX.IntrinsicElements {}
  }
}"
`;

