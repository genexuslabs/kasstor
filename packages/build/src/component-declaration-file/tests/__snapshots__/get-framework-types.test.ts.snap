exports[`[component-declaration-file] getStencilDeclaration > imports @stencil/core + the core ComponentProperties and augments Stencil JSX 1`] = `
"import type { JSXBase } from "@stencil/core/internal";
// Empty import so the bare "@stencil/core" module is known to the augmentation
// below (augmenting a module requires it to be resolvable in the program).
import type {} from "@stencil/core";
import type { ComponentProperties } from "./components.js";

// - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
// Types for StencilJS JSX templates
// - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
// eslint-disable-next-line @typescript-eslint/no-namespace
declare namespace StencilJSX {
  export type KstField = Omit<JSXBase.HTMLAttributes<HTMLKstFieldElement>, keyof ComponentProperties.KstField> & Partial<ComponentProperties.KstField> & {
    /**
     * Selection changed.
     */
    onSelectedItemsChange?: (event: HTMLKstFieldElementSelectedItemsChangeEvent) => void;
  };

  export type KstIcon = Omit<JSXBase.HTMLAttributes<HTMLKstIconElement>, keyof ComponentProperties.KstIcon> & Partial<ComponentProperties.KstIcon>;
  
  interface IntrinsicElements {
    /**
     * A form field.
     */
    "kst-field": KstField;
    
    /**
     * An icon.
     */
    "kst-icon": KstIcon;
  }
}

export type { StencilJSX };

declare module "@stencil/core" {
  // eslint-disable-next-line @typescript-eslint/no-namespace
  export namespace JSX {
    // eslint-disable-next-line @typescript-eslint/no-empty-object-type
    interface IntrinsicElements extends StencilJSX.IntrinsicElements {}
  }
}"
`;
