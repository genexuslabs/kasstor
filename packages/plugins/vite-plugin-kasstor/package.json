{
  "name": "@genexus/vite-plugin-kasstor",
  "version": "0.2.0",
  "license": "Apache-2.0",
  "homepage": "https://github.com/genexuslabs/kasstor",
  "description": "Vite plugin that wires @genexus/kasstor-build and @genexus/kasstor-insights into a single entry point and adds HMR for components built with @genexus/kasstor-core.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/genexuslabs/kasstor.git"
  },
  "keywords": [
    "lit",
    "lit decorators",
    "vite",
    "web components"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "jsnext:main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "files": [
    "dist/"
  ],
  "scripts": {
    "dev": "tsc",
    "dev.types": "tsc",
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "playwright install && vitest",
    "test.ci": "bun run test --watch=false --browser.headless",
    "test:unit": "vitest --project unit",
    "test:e2e": "playwright install && vitest --project browser"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "peerDependencies": {
    "@genexus/kasstor-build": "~0.1.1",
    "@genexus/kasstor-core": "~0.2.0",
    "@genexus/kasstor-insights": "~0.2.0",
    "oxc-resolver": "^11.10.0",
    "vite": "^6.0.0 || ^7.0.0 || ^8.0.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  }
}

