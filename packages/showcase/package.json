{
  "name": "@genexus/kasstor-showcase",
  "private": true,
  "version": "0.1.0",
  "license": "Apache-2.0",
  "homepage": "https://github.com/genexuslabs/kasstor",
  "description": "A set of utilities to build and test Lit applications and libraries.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/genexuslabs/kasstor.git"
  },
  "keywords": [
    "lit",
    "lit decorators",
    "web components"
  ],
  "main": "./dist/browser/production/index.js",
  "module": "./dist/browser/production/index.js",
  "jsnext:main": "./dist/browser/production/index.js",
  "types": "./dist/browser/development/index.d.ts",
  "type": "module",
  "files": [
    "dist/"
  ],
  "scripts": {
    "start": "vite --port 5200 --open",
    "test": "playwright install && vitest",
    "test.ci": "bun run test --watch=false --browser.headless",
    "test:unit": "vitest --project unit",
    "test:e2e": "playwright install && vitest --project browser"
  },
  "dependencies": {
    "@genexus/chameleon-controls-library": "~6.28.0",
    "@genexus/kasstor-core": "workspace:*",
    "@genexus/kasstor-signals": "workspace:*",
    "@genexus/kasstor-webkit": "workspace:*",
    "@genexus/mercury": "1.0.0",
    "lit": "~3.3.1"
  },
  "devDependencies": {
    "@genexus/vite-plugin-mercury": "1.0.0",
    "@genexus/vite-plugin-kasstor": "workspace:*",
    "@jackolope/ts-lit-plugin": "^3.1.6",
    "web-component-analyzer": "~2.0.0"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  }
}

