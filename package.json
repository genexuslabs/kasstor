{
  "name": "@genexus/kasstor-monorepo",
  "version": "0.4.0",
  "private": true,
  "homepage": "https://github.com/genexuslabs/kasstor/",
  "description": "Ecosystem for building Lit-based web components with first-class DX: decorators, SCSS, typed events, HMR, optional signals.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/genexuslabs/kasstor.git"
  },
  "keywords": [
    "lit",
    "lit decorators",
    "web components"
  ],
  "workspaces": [
    "packages/*",
    "packages/plugins/*"
  ],
  "scripts": {
    "start": "cd packages/showcase && bun start",
    "dev": "bun dev:webkit && bun dev:core && bun dev:insights && bun dev:build && bun dev:signals && bun dev:vite-plugin",
    "dev:build": "cd packages/build && bun dev",
    "dev:core": "cd packages/core && bun dev",
    "dev:insights": "cd packages/insights && bun dev",
    "dev:signals": "cd packages/signals && bun dev",
    "dev:vite-plugin": "cd packages/plugins/vite-plugin-kasstor && bun dev",
    "dev:webkit": "cd packages/webkit && bun dev",
    "build": "bun build:webkit && bun build:core && bun build:insights && bun build:build && bun build:signals && bun build:vite-plugin",
    "build:build": "cd packages/build && bun run build",
    "build:core": "cd packages/core && bun run build",
    "build:insights": "cd packages/insights && bun run build",
    "build:signals": "cd packages/signals && bun run build",
    "build:vite-plugin": "cd packages/plugins/vite-plugin-kasstor && bun run build",
    "build:webkit": "cd packages/webkit && bun run build",
    "watch": "concurrently 'bun build:core --watch' 'bun build:signals --watch' 'bun build:webkit --watch'",
    "test": "bun dev && playwright install && vitest",
    "test.ci": "bun run test --watch=false --browser.headless",
    "test:unit": "bun dev && vitest --project unit",
    "test:e2e": "bun dev && playwright install && vitest --project browser"
  },
  "license": "Apache-2.0",
  "devDependencies": {
    "@eslint/js": "~9.36.0",
    "@typescript-eslint/eslint-plugin": "~8.44.1",
    "@typescript-eslint/parser": "~8.44.1",
    "@typescript/native-preview": "~7.0.0-dev.20260222.1",
    "@types/node": "~22.15.17",
    "@vitest/browser": "~4.0.18",
    "@vitest/coverage-v8": "~4.0.18",
    "@vitest/ui": "~4.0.18",
    "@vitest/browser-playwright": "~4.0.18",
    "ajv": "~8.17.1",
    "concurrently": "~9.2.0",
    "eslint": "~9.36.0",
    "globals": "~16.4.0",
    "minify-html-literals": "~1.3.5",
    "playwright": "~1.55.1",
    "prettier": "~3.6.2",
    "rollup": "~4.40.2",
    "rollup-plugin-summary": "~3.0.1",
    "rollup-plugin-minify-html-literals": "^1.2.6",
    "typescript": "~5.9.2",
    "typescript-eslint": "~8.32.0",
    "vite": "7.3.2",
    "vitest": "~4.0.18",
    "vitest-browser-lit": "~0.1.0"
  },
  "overrides": {
    "@genexus/kasstor-build": "workspace:*",
    "@genexus/kasstor-core": "workspace:*",
    "@genexus/kasstor-insights": "workspace:*",
    "@genexus/kasstor-webkit": "workspace:*",
    "vite": "7.3.2"
  }
}
