{
  "name": "@genexus/kasstor-monorepo",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://github.com/genexuslabs/kasstor/",
  "description": "A set of utilities to build and test Lit applications and libraries.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/genexuslabs/kasstor.git"
  },
  "keywords": [
    "lit",
    "lit decorators",
    "web components"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently 'bun dev:core' 'bun dev:webkit'",
    "dev:core": "cd packages/core && bun dev",
    "dev:webkit": "cd packages/webkit && bun dev",
    "build": "bun build:webkit && bun build:core",
    "build:core": "cd packages/core && bun run build",
    "build:webkit": "cd packages/webkit && bun run build",
    "watch": "concurrently 'bun build:core --watch' 'bun build:webkit --watch'",
    "test": "bunx playwright install && vitest",
    "test.ci": "bun run test --watch=false --browser.headless",
    "test.ui": "bun run test --ui"
  },
  "license": "Apache-2.0",
  "devDependencies": {
    "@eslint/js": "~9.36.0",
    "@typescript-eslint/eslint-plugin": "~8.44.1",
    "@typescript-eslint/parser": "~8.44.1",
    "@typescript/native-preview": "~7.0.0-dev.20251128.1",
    "@types/node": "~22.15.17",
    "@vitest/browser": "~3.2.4",
    "@vitest/coverage-v8": "~3.2.4",
    "@vitest/ui": "~3.2.4",
    "ajv": "~8.17.1",
    "concurrently": "~9.2.0",
    "eslint": "~9.36.0",
    "globals": "~16.4.0",
    "playwright": "~1.55.1",
    "prettier": "~3.6.2",
    "rollup": "~4.40.2",
    "rollup-plugin-summary": "~3.0.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "~8.32.0",
    "vite": "~7.1.7",
    "vitest": "~3.2.4",
    "vitest-browser-lit": "~0.1.0"
  },
  "overrides": {
    "@genexus/kasstor-webkit": "workspace:*"
  }
}
